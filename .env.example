# ============================================================
# LLM Provider — "bedrock" or "local"
# ============================================================
LLM_PROVIDER=local

# ============================================================
# AWS Credentials  (required only when LLM_PROVIDER=bedrock)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ============================================================
# Local Model  (required when LLM_PROVIDER=local)
# LM Studio or any OpenAI-compatible inference server
# ============================================================
LOCAL_MODEL_BASE_URL=http://localhost:1234/v1
LOCAL_MODEL_NAME=your-model-name
LOCAL_MODEL_API_KEY=not-needed

# ============================================================
# API Security
# ============================================================
API_KEY=dev-secret-key-change-in-prod

# ============================================================
# JWT
# ============================================================
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============================================================
# App Config
# ============================================================
APP_ENV=development
LOG_LEVEL=INFO
SYSTEM_PROMPT=You are a helpful AI assistant.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ============================================================
# Database Pool
# ============================================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ============================================================
# Agent
# ============================================================
AGENT_TIMEOUT_SECONDS=120

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT=60/minute

# ============================================================
# ChromaDB Vector Store
# ============================================================
CHROMA_HOST=localhost
CHROMA_PORT=8001
# Set to "true" to use HTTP client (remote ChromaDB), "false" for local persistence
CHROMA_USE_HTTP=false

# ============================================================
# Context Window / Memory Management
# ============================================================
CONTEXT_MAX_TOKENS=48000
CONTEXT_SLIDING_WINDOW_TURNS=10
CONTEXT_SUMMARY_ENABLED=true

# ============================================================
# Session Limits
# ============================================================
MAX_TURNS_PER_SESSION=100
SESSION_EXPIRY_HOURS=24

# ============================================================
# JWT Auto-Refresh
# ============================================================
JWT_AUTO_REFRESH=true
JWT_REFRESH_THRESHOLD_PERCENT=25
