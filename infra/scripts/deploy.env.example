# ============================================================
# Bob AWS Deployment Configuration
# Copy to deploy.env and fill in your values
# ============================================================

# AWS Configuration
AWS_PROFILE=default
AWS_REGION=us-east-1
STACK_NAME=bob-prod

# Domain Configuration
DOMAIN_NAME=example.com
SUBDOMAIN_NAME=bob
HOSTED_ZONE_ID=ZXXXXXXXXXX

# EC2 Configuration
INSTANCE_TYPE=t4g.small
ROOT_VOLUME_SIZE=30
KEY_PAIR_NAME=bob-prod
SSH_KEY_PATH=/path/to/bob-prod.pem
TRUSTED_SSH_CIDR=0.0.0.0/0
REMOTE_USER=ec2-user

# Database (MariaDB on EC2)
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Elastic IP (auto-detected from stack outputs after first deploy)
# Uncomment and set manually to skip stack output lookup:
# ELASTIC_IP=x.x.x.x

# ============================================================
# Application .env values (templated to EC2 on first deploy)
# ============================================================

# LLM
LLM_PROVIDER=local
LOCAL_MODEL_BASE_URL=http://localhost:1234/v1
LOCAL_MODEL_NAME=your-model-name
LOCAL_MODEL_EMBED_NAME=text-embedding-nomic-embed-text-v1.5
LOCAL_MODEL_API_KEY=CHANGE_ME

# Security
API_KEY=CHANGE_ME_PROD_API_KEY
JWT_SECRET=CHANGE_ME_PROD_JWT_SECRET

# Whisper (Speech-to-Text)
WHISPER_BASE_URL=https://your-whisper-server/v1
WHISPER_API_KEY=CHANGE_ME

# TTS (Text-to-Speech — Kokoro)
TTS_BASE_URL=https://your-tts-server/v1
TTS_API_KEY=
TTS_MODEL=kokoro
TTS_VOICE=af_heart

# Piper TTS (Romanian / secondary)
PIPER_BASE_URL=https://your-piper-server/v1
PIPER_API_KEY=
PIPER_MODEL=piper
PIPER_VOICE=ro_RO-mihai-medium

# Email (SMTP)
MAIL_USERNAME=mail@example.com
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS=mail@example.com
ADMIN_APPROVAL_EMAIL=admin@example.com

# n8n (workflow automation)
N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_API_KEY=CHANGE_ME

# Google OAuth (Gmail — multi-tenant per-user)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://bob.example.com/api/v1/email/callback/gmail
BASE_URL=https://bob.example.com
